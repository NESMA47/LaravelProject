                { "key": "file", "type": "file", "src": "" },
                { "key": "file_type", "value": "avatar", "type": "text" },
                { "key": "entity_type", "value": "candidate", "type": "text" },
                { "key": "entity_id", "value": "1", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Upload Company Logo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
