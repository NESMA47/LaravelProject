                { "key": "entity_type", "value": "employer", "type": "text" },
                { "key": "entity_id", "value": "1", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Upload Verification Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/files/upload",
