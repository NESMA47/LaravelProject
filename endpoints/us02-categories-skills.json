{
  "info": {
    "name": "HireMasr API - US2 Categories & Skills",
    "_postman_id": "hiremasr-us2-collection",
    "description": "User Story 2 endpoints for categories and skills taxonomy (public + admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "skill_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public - Categories",
      "item": [
        {
          "name": "List Active Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('category_id', res.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Category by Slug",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/categories/software-development",
              "host": ["{{base_url}}"],
              "path": ["categories", "software-development"]
            }
          }
        }
      ]
    },
    {
      "name": "Public - Skills",
      "item": [
        {
          "name": "List All Active Skills",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/skills",
              "host": ["{{base_url}}"],
              "path": ["skills"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('skill_id', res.data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Skills by Category",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/skills?category_id={{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["skills"],
              "query": [
                { "key": "category_id", "value": "{{category_id}}" }
              ]
            }
          }
        },
        {
          "name": "Skills Autocomplete",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/skills/autocomplete?q=vue",
              "host": ["{{base_url}}"],
              "path": ["skills", "autocomplete"],
              "query": [
                { "key": "q", "value": "vue" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Authenticated - Skills",
      "item": [
        {
          "name": "Create Skill (Any Auth User)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/skills",
              "host": ["{{base_url}}"],
              "path": ["skills"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Svelte\",\n  \"category_id\": \"{{category_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('skill_id', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin - Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/categories",
              "host": ["{{base_url}}"],
              "path": ["admin", "categories"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cybersecurity\",\n  \"icon\": \"Shield\",\n  \"description\": \"Security engineering, pentesting, and compliance roles\",\n  \"display_order\": 10\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "categories", "{{category_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Category Name\",\n  \"description\": \"Updated description\",\n  \"display_order\": 99\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Category Slug (Explicit)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "categories", "{{category_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"custom-slug\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "categories", "{{category_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Skills",
      "item": [
        {
          "name": "Create Skill (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/skills",
              "host": ["{{base_url}}"],
              "path": ["admin", "skills"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rust\",\n  \"category_id\": \"{{category_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Skill",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/skills/{{skill_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "skills", "{{skill_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Skill Name\",\n  \"category_id\": \"{{category_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Skill Slug (Explicit)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/skills/{{skill_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "skills", "{{skill_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"custom-skill-slug\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Skill",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/skills/{{skill_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "skills", "{{skill_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth Helpers",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hiremasr.com\",\n  \"password\": \"AdminPass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('admin_token', res.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Candidate/Employer Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.access_token) {",
                  "  pm.collectionVariables.set('token', res.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
